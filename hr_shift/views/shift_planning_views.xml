<?xml version="1.0" ?>
<odoo>
    <record id="shift_planning_form" model="ir.ui.view">
        <field name="model">hr.shift.planning</field>
        <field name="arch" type="xml">
            <form>
                <header position="inside">
                    <field
                        name="state"
                        widget="statusbar"
                        readonly="0"
                        options="{'clickable': '1'}"
                    />
                    <field name="shift_ids" invisible="1" />
                    <button
                        type="object"
                        name="generate_shifts"
                        class="btn btn-primary"
                        string="Generate shifts"
                        invisible="state != 'new' or not end_date"
                    />
                    <button
                        type="object"
                        name="copy_to_planning"
                        class="btn btn-secondary"
                        string="Copy to new planning"
                        invisible="state == 'new' or not shift_ids"
                    />
                    <button
                        type="object"
                        name="regenerate_shifts"
                        class="btn btn-secondary"
                        string="Regenerate shifts"
                        invisible="state != 'assignment' or not shift_ids"
                        confirm="This will remove the current shifts assignations for this planning"
                    />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            class="oe_stat_button"
                            name="action_view_shifts"
                            type="object"
                            invisible="state == 'new'"
                            icon="fa-link"
                        >
                            <field
                                name="shifts_count"
                                string="Shifts"
                                widget="statinfo"
                            />
                        </button>
                        <button
                            class="oe_stat_button"
                            name="action_view_issued_shifts"
                            type="object"
                            invisible="state == 'new' or issued_shifts_count == 0"
                            icon="fa-unlink"
                        >
                            <field
                                name="issued_shifts_count"
                                string="Issues"
                                widget="statinfo"
                            />
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="year" readonly="state != 'new'" />
                            <field name="week_number" readonly="state != 'new'" />
                        </group>
                        <group>
                            <field name="start_date" readonly="state != 'new'" />
                            <field name="end_date" force_save="1" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="shift_planning_kanban" model="ir.ui.view">
        <field name="model">hr.shift.planning</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_full_width" js_class="shift_planning_kanban">
                <field name="display_name" />
                <field name="days_data" />
                <field name="issued_shifts_count" />
                <field name="shifts_count" />
                <templates>
                    <t t-name="card">
                        <main class="d-flex align-items-center w-100 p-3">
                            <div class="d-flex align-items-center gap-3 w-100">
                                <div class="d-flex flex-column gap-2">
                                    <button
                                        name="action_view_shifts"
                                        type="object"
                                        class="btn btn-primary"
                                        t-if="record.shifts_count.raw_value"
                                    ><span
                                        class="badge text-bg-light text-primary me-1"
                                        t-esc="record.shifts_count.value"
                                    /> Shifts</button>
                                    <button
                                        name="action_view_issued_shifts"
                                        type="object"
                                        class="btn btn-danger"
                                        t-if="record.issued_shifts_count.raw_value"
                                    ><span
                                        class="badge text-bg-light text-danger me-1"
                                        t-esc="record.issued_shifts_count.value"
                                    /> Issues</button>
                                </div>
                                <div class="flex-grow-1 d-flex justify-content-center">
                                    <div
                                        t-if="record.days_data.raw_value"
                                        class="btn-group"
                                        role="group"
                                        aria-label="Shifts"
                                    >
                                        <t
                                            t-foreach="record.days_data.raw_value"
                                            t-as="day"
                                            t-key="day"
                                        >
                                            <t t-if="day.state === 'assigned'">
                                                <t t-set="color" t-value="'success'" />
                                            </t>
                                            <t t-elif="day.state === 'unavailable'">
                                                <t t-set="color" t-value="'danger'" />
                                            </t>
                                            <t t-elif="day.state === 'holiday'">
                                                <t t-set="color" t-value="'dark'" />
                                            </t>
                                            <t t-elif="day.state === 'on_leave'">
                                                <t t-set="color" t-value="'warning'" />
                                            </t>
                                            <t t-else="">
                                                <t t-set="color" t-value="'light'" />
                                            </t>
                                            <button
                                                type="object"
                                                name="action_view_day_shifts"
                                                t-attf-class="btn border btn-#{color} text-center fw-bold"
                                                t-attf-context="{'weekday_number': #{day_value.weekday_number} }"
                                            >
                                                <small
                                                    t-esc="day_value.weekday.slice(0, 3)"
                                                    class="text-uppercase"
                                                />
                                                <br />
                                                <small t-esc="day_value.day" />
                                            </button>
                                        </t>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <h3>
                                        <i
                                            class="fa fa-calendar text-primary me-2"
                                            role="img"
                                            title="Planning"
                                        />
                                        <t t-esc="record.display_name.value" />
                                    </h3>
                                </div>
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="shift_planning_calendar" model="ir.ui.view">
        <field name="model">hr.shift.planning</field>
        <field name="arch" type="xml">
            <calendar
                date_start="start_date"
                date_stop="end_date"
                mode="month"
                scales="month,year"
                color="id"
                event_open_popup="1"
            >
                <field name="display_name" />
            </calendar>
        </field>
    </record>
    <record id="shift_planning_tree" model="ir.ui.view">
        <field name="model">hr.shift.planning</field>
        <field name="arch" type="xml">
            <list js_class="shift_planning_tree">
                <field name="year" />
                <field name="week_number" />
                <field name="start_date" />
                <field name="end_date" />
            </list>
        </field>
    </record>
    <record id="shift_planning_shift_search" model="ir.ui.view">
        <field name="model">hr.shift.planning.shift</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id" />
                <field name="template_id" />
                <field name="planning_id" />
            </search>
        </field>
    </record>
    <record id="shift_planning_shift_tree" model="ir.ui.view">
        <field name="model">hr.shift.planning.shift</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="employee_id" />
                <field name="template_id" />
                <field name="planning_id" column_invisible="True" />
            </list>
        </field>
    </record>
    <record id="shift_planning_shift_kanban" model="ir.ui.view">
        <field name="model">hr.shift.planning.shift</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="id" />
                <field name="template_id" />
                <field name="employee_id" />
                <field name="line_ids" />
                <field name="lines_data" />
                <field name="color" />
                <field name="reviewed" />
                <progressbar field="template_id" colors='{}' />
                <templates>
                    <t t-name="card" class="d-flex flex-column">
                        <aside
                            class="d-flex justify-content-between align-items-baseline"
                        >
                            <div class="d-flex align-items-center">
                                <field
                                    name="employee_id"
                                    widget="image"
                                    options="{'preview_image': 'image_128', 'size': [24, 24]}"
                                    class="rounded-circle me-2"
                                />
                                <strong t-esc="record.employee_id.value" />
                            </div>
                            <a
                                class="btn"
                                type="object"
                                name="action_toggle_reviewed"
                                role="button"
                                title="Set as reviewed"
                            >
                                <span
                                    t-if="record.reviewed.raw_value"
                                    class="fa fa-check-square-o text-success"
                                />
                                <span t-else="" class="fa fa-square-o" />
                            </a>
                        </aside>
                        <main t-if="record.line_ids.raw_value">
                            <div
                                class="d-flex justify-content-between align-items-center gap-2"
                            >
                                <div class="d-flex">
                                    <t
                                        t-foreach="record.lines_data.raw_value"
                                        t-as="line"
                                        t-key="line"
                                    >
                                        <t t-if="line_value.state === 'assigned'">
                                            <t
                                                t-set="color"
                                                t-value="'o_button_color_' + line_value.color"
                                            />
                                        </t>
                                        <t t-elif="line_value.state === 'unavailable'">
                                            <t t-set="color" t-value="'btn-danger'" />
                                        </t>
                                        <t t-elif="line_value.state === 'holiday'">
                                            <t t-set="color" t-value="'btn-dark'" />
                                        </t>
                                        <t t-elif="line_value.state === 'on_leave'">
                                            <t t-set="color" t-value="'btn-danger'" />
                                        </t>
                                        <t t-else="">
                                            <t t-set="color" t-value="'btn-light'" />
                                        </t>
                                        <button
                                            t-attf-class="btn border btn-sm #{color}"
                                            type="object"
                                            name="action_view_shift_details"
                                            t-attf-context="{'shift_line_id': #{line} }"
                                        >
                                            <t t-esc="line_value.day.slice(0, 2)" />
                                        </button>
                                    </t>
                                </div>
                                <button
                                    t-if="record.line_ids.raw_value"
                                    type="object"
                                    class="btn btn-primary btn-sm"
                                    name="action_view_shift_details"
                                >Shift details</button>
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="shift_planning_line_search" model="ir.ui.view">
        <field name="model">hr.shift.planning.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id" />
                <field name="template_id" />
                <field name="planning_id" />
                <filter
                    name="filter_my_shifts"
                    string="My shifts"
                    domain="[('employee_id.user_id', '=', uid)]"
                />
                <group string="Group By">
                    <filter
                        name="group_template"
                        string="Template"
                        context="{'group_by':'template_id'}"
                    />
                    <filter
                        name="group_employee"
                        string="Employee"
                        context="{'group_by':'employee_id'}"
                    />
                </group>
            </search>
        </field>
    </record>
    <record id="shift_planning_line_tree" model="ir.ui.view">
        <field name="model">hr.shift.planning.line</field>
        <field name="arch" type="xml">
            <list create="0">
                <field name="employee_id" widget="many2one_avatar_employee" />
                <field name="template_id" />
                <field name="day_number" />
                <field name="start_time" />
                <field name="end_time" />
                <field name="planning_id" column_invisible="True" />
                <field name="shift_id" column_invisible="True" />
            </list>
        </field>
    </record>
    <record id="shift_planning_line_kanban" model="ir.ui.view">
        <field name="model">hr.shift.planning.line</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="id" />
                <field name="template_id" />
                <field name="employee_id" />
                <field name="day_number" />
                <field name="start_time" />
                <field name="end_time" />
                <field name="start_date" />
                <field name="state" />
                <progressbar field="template_id" colors='{}' />
                <templates>
                    <t
                        t-name="card"
                        t-attf-class="d-flex justify-content-between #{record.state.raw_value === 'holiday' ? 'bg-dark' : record.state.raw_value === 'on_leave' ? 'bg-danger' : ''}"
                    >
                        <aside
                            class="d-flex align-items-baseline justify-content-between"
                        >
                            <div class="d-flex gap-2">
                                <div t-if="context.multi_employee_mode">
                                    <strong>
                                        <field name="employee_id" />
                                    </strong>
                                </div>
                                <div t-else="" class="d-flex gap-2">
                                    <strong class="text-uppercase">
                                        <field name="day_number" />
                                    </strong>
                                    <field name="start_date" />
                                </div>
                                <span
                                    t-if="['holiday', 'on_leave'].includes(record.state.raw_value)"
                                    class="badge bg-secondary"
                                    t-esc="record.state.value"
                                />
                            </div>
                            <button
                                t-if="record.template_id.raw_value"
                                class="btn btn-link"
                                type="object"
                                name="action_unassign_shift"
                                title="Unassign"
                            >
                                <i class="fa fa-times" role="img" />
                            </button>
                        </aside>
                        <main class="flex-grow-1">
                            <div
                                t-if="record.template_id.raw_value"
                                title="Shift span"
                                class="d-flex align-items-center gap-2"
                            >
                                <span class="badge bg-light">
                                    <span t-esc="record.template_id.value" />
                                </span>
                                <i
                                    class="fa fa-arrow-circle-right text-success"
                                    role="img"
                                />
                                <field name="start_hour" widget="float_time" />
                                <i class="fa fa-long-arrow-right" role="img" />
                                <i class="fa fa-clock-o text-danger" role="img" />
                                <field name="end_hour" widget="float_time" />
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="shift_planning_line_calendar" model="ir.ui.view">
        <field name="model">hr.shift.planning.line</field>
        <field name="arch" type="xml">
            <calendar
                date_start="start_time"
                date_stop="end_time"
                mode="month"
                scales="week,month,year"
                color="color"
                event_open_popup="1"
                create="0"
                delete="0"
            >
                <field name="template_id" filters="1" color="color" />
                <field name="employee_id" filters="1" />
            </calendar>
        </field>
    </record>
    <record id="shift_planning_line_form" model="ir.ui.view">
        <field name="model">hr.shift.planning.line</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="start_date" />
                            <field name="day_number" readonly="1" />
                            <field name="employee_id" readonly="1" />
                        </group>
                        <group>
                            <field
                                name="template_id"
                                string="Shift"
                                readonly="True"
                                groups="!hr_shift.group_shift_manager"
                            />
                            <field
                                name="template_id"
                                string="Shift"
                                groups="hr_shift.group_shift_manager"
                            />
                            <field name="start_time" readonly="1" />
                            <field name="end_time" readonly="1" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="shift_planning_shift_action" model="ir.actions.act_window">
        <field name="res_model">hr.shift.planning.shift</field>
        <field name="view_mode">kanban,list,form</field>
        <field
            name="context"
        >{'group_by': 'template_id', 'default_planning_id': active_id}</field>
        <field name="domain">[('planning_id', '=', active_id)]</field>
    </record>
    <record id="shift_planning_line_action" model="ir.actions.act_window">
        <field name="res_model">hr.shift.planning.line</field>
        <field name="view_mode">kanban,calendar,list,form</field>
        <field name="context">{'group_by': 'template_id'}</field>
        <field name="domain">[('shift_id', '=', active_id)]</field>
    </record>
    <record id="shift_planning_day_detail_action" model="ir.actions.act_window">
        <field name="res_model">hr.shift.planning.line</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'group_by': 'template_id'}</field>
        <field name="domain">[('shift_id.planning_id', '=', active_id)]</field>
    </record>
    <record id="my_shifts_planning_action" model="ir.actions.act_window">
        <field name="res_model">hr.shift.planning.line</field>
        <field name="view_mode">calendar,list</field>
        <field name="context">{'search_default_filter_my_shifts': 1}</field>
        <field name="domain">[('state', '!=', 'unassigned')]</field>
    </record>
    <record id="shift_planning_action" model="ir.actions.act_window">
        <field name="res_model">hr.shift.planning</field>
        <field name="view_mode">kanban,list,calendar,form</field>
    </record>
    <menuitem
        id="shift_planning_root"
        name="Shifts"
        web_icon="hr_shift,static/description/icon.png"
        sequence="100"
    />
    <menuitem
        id="shift_planning_menu"
        name="Planning"
        parent="shift_planning_root"
        action="shift_planning_action"
        sequence="10"
        groups="hr_shift.group_shift_manager"
    />
    <menuitem
        id="my_shifts_menu"
        name="My shifts"
        parent="shift_planning_root"
        action="my_shifts_planning_action"
        sequence="20"
    />
</odoo>
